<launch>
  <arg name="use_sim_time" default="true"/>
  <arg name="frame_id" default="odom"/>
  <arg name="params_file" default="$(find-pkg-share world_model_nav_ros2)/config/world_model_nav.yaml"/>
  <arg name="policy_path" default="$(find-pkg-share world_model_nav_ros2)/model/best.pt"/>

  <node pkg="world_model_nav_ros2" exec="world_model_nav_node.py" name="world_model_nav" output="screen">
    <param from="$(var params_file)"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="frame_id" value="$(var frame_id)"/>
    <param name="policy_path" value="$(var policy_path)"/>
  </node>
</launch>
