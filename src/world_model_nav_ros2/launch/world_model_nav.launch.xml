<launch>
  <arg name="use_sim_time" default="true"/>
  <arg name="frame_id" default="odom"/>
  <arg name="params_file" default="$(find-pkg-share world_model_nav_ros2)/config/world_model_nav.yaml"/>
  <arg name="policy_path" default="$(find-pkg-share world_model_nav_ros2)/model/best.pt"/>

  <node pkg="go2_nav2" exec="maximin_astar_planner_node" name="world_model_nav_astar_planner" output="screen">
    <param from="$(var params_file)"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="frame_id" value="$(var frame_id)"/>
  </node>

  <node pkg="world_model_nav_ros2" exec="waypoint_tracker_node.py" name="world_model_nav_waypoint_tracker" output="screen">
    <param from="$(var params_file)"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="frame_id" value="$(var frame_id)"/>
  </node>

  <node pkg="world_model_nav_ros2" exec="policy_controller_node.py" name="world_model_nav_policy_controller" output="screen">
    <param from="$(var params_file)"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="frame_id" value="$(var frame_id)"/>
    <param name="policy_path" value="$(var policy_path)"/>
  </node>

  <node pkg="world_model_nav_ros2" exec="map_image_publisher_node.py" name="world_model_nav_map_image_publisher" output="screen">
    <param from="$(var params_file)"/>
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="frame_id" value="$(var frame_id)"/>
  </node>
</launch>
